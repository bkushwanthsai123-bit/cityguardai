# Smart City Garbage Detection - environment configuration
# Copy to .env and adjust as needed. Read by app/config.py (pydantic-settings).

# --- Database ---
# SQLite default; swap for Postgres e.g. postgresql+psycopg://user:pass@host:5432/smartcity
DB_URL=sqlite:///./smartcity.db

# --- Detection model ---
# Trained weights; if missing the app falls back to yolov8n.pt so it still boots.
MODEL_PATH=ml/weights/best.pt
CONF_THRESHOLD=0.25

# --- LLM layer ---
# Default is a lightweight, CPU-friendly 1B model (~4s/report on an Apple M1,
# no GPU needed). Swap LLM_MODEL for a larger model (e.g. llama3.1:8b) if a GPU
# is available.
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:1b
OLLAMA_HOST=http://localhost:11434

# --- Storage ---
UPLOAD_DIR=./uploads
